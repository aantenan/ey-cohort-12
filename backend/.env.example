APP_NAME=EY Cohort 12 API
ENVIRONMENT=local
DEBUG=false

API_V1_PREFIX=/api/v1
HOST=127.0.0.1
PORT=8000

# Comma-separated CORS origins (include both localhost and 127.0.0.1 for Angular :4200)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4200,http://127.0.0.1:4200

# Microsoft Entra ID — required for JWT-protected routes (`/api/v1/common/*`)
ENTRA_TENANT_ID=
ENTRA_AUDIENCE=
# Optional override; default issuer is https://login.microsoftonline.com/{tenant}/v2.0
ENTRA_ISSUER=

# true = no JWT required (local dev). Set false for Entra-secured API.
AUTH_DISABLED=true

# Sync URL for Alembic; async URL for runtime (same SQLite file in dev)
DATABASE_URL_SYNC=sqlite:///./local.db
DATABASE_URL=sqlite+aiosqlite:///./local.db

# Redis — leave empty to disable Redis + WebSocket pub/sub bridge (tests)
REDIS_URL=redis://127.0.0.1:6379/0

# Azure Service Bus — leave empty to skip publishing
AZURE_SERVICE_BUS_CONNECTION_STRING=

# Integration API keys (local): JSON map `ivr` / `chatbot`
INTEGRATION_API_KEYS_JSON={"ivr":"local-ivr","chatbot":"local-chat"}

# Key Vault (staging/prod) — when set, AzureCredential loads secrets by name (see config defaults)
KEY_VAULT_URL=
